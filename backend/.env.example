# Solana RPC endpoint (devnet default)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed program ID (run `cd scripts && npx tsx bootstrap-devnet.ts` to get these values)
PROGRAM_ID=ETu1YLCnZyeeWBYYLSFXLNncJa4AgaHaZQ8JSUxTEosJ

# On-chain addresses from bootstrap script output
USDC_MINT_ADDRESS=
POOL_MINT_ADDRESS=
HARDWARE_OWNER_ADDRESS=

# Co-signer keypair for consume_receipt (generated by bootstrap script)
COSIGNER_KEYPAIR_PATH=./keys/cosigner.json
COSIGNER_KEY_JSON=

# Sensor device keypair for Ed25519 data signing (generated by bootstrap script)
SENSOR_KEYPAIR_PATH=./keys/sensor.json
SENSOR_KEY_JSON=

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
