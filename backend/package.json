{
  "name": "sol-sensor-backend",
  "version": "1.0.0",
  "description": "HTTP 402 micro-payment gateway for SolSensor — machine-to-machine IoT data monetization on Solana",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
