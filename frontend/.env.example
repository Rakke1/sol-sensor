# SolSensor Frontend Environment Variables
# Copy this file to .env.local and fill in values for your environment

# Solana RPC endpoint (defaults to devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed SolSensor Anchor program ID
NEXT_PUBLIC_PROGRAM_ID=

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Solana network label displayed in the UI
NEXT_PUBLIC_SOLANA_NETWORK=devnet
