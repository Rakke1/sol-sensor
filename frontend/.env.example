# SolSensor Frontend Environment Variables
# Copy this file to .env.local and fill in values for your environment
# Run `cd scripts && npx tsx bootstrap-devnet.ts` to get the on-chain addresses

# Solana RPC endpoint (defaults to devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed SolSensor Anchor program ID
NEXT_PUBLIC_PROGRAM_ID=ETu1YLCnZyeeWBYYLSFXLNncJa4AgaHaZQ8JSUxTEosJ

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Solana network label displayed in the UI
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# On-chain addresses from bootstrap script output
NEXT_PUBLIC_USDC_MINT_ADDRESS=
NEXT_PUBLIC_POOL_MINT_ADDRESS=
